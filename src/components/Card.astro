---
interface Props {
  title?: string;
  description?: string;
  icon?: string;
  href?: string;
  class?: string;
}

const { title, description, icon, href, class: className = "" } = Astro.props;
---

<div class={`card glass-panel ${className}`}>
  {href ? (
    <a href={href} class="card-link-wrapper">
      <slot name="icon">
        {icon && <div class="card-icon">{icon}</div>}
      </slot>
      <slot name="content">
        {title && <h3 class="card-title">{title}</h3>}
        {description && <p class="card-desc">{description}</p>}
      </slot>
      <slot />
    </a>
  ) : (
    <div class="card-content-wrapper">
      <slot name="icon">
        {icon && <div class="card-icon">{icon}</div>}
      </slot>
      <slot name="content">
        {title && <h3 class="card-title">{title}</h3>}
        {description && <p class="card-desc">{description}</p>}
      </slot>
      <slot />
    </div>
  )}
</div>

<style>
  .card {
    padding: var(--space-4);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal), border-color var(--transition-normal);
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-glow);
    border-color: var(--border-strong);
  }
  
  .card-link-wrapper, .card-content-wrapper {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: var(--space-3);
  }
  
  .card-icon {
    font-size: 2.5rem;
    margin-bottom: var(--space-2);
  }
  
  .card-title {
    font-size: 1.25rem;
    color: var(--text-main);
  }
  
  .card-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
    flex-grow: 1;
  }
</style>
