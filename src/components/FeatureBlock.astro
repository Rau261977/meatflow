---
interface Props {
  title: string;
  description: string;
  subtext?: string;
  image?: string;
  reverse?: boolean;
}

const { title, description, subtext, image, reverse = false } = Astro.props;
---

<div class={`feature-block ${reverse ? 'reverse' : ''}`}>
  <div class="feature-content">
    {subtext && <span class="text-gradient-accent subtext">{subtext}</span>}
    <h2>{title}</h2>
    <p class="description">{description}</p>
    <slot name="actions" />
  </div>
  <div class="feature-visual">
    <slot name="visual">
      {image ? (
        <img src={image} alt={title} class="feature-image" />
      ) : (
        <div class="visual-placeholder glass-panel"></div>
      )}
    </slot>
  </div>
</div>

<style>
  .feature-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
    padding: var(--space-8) 0;
  }
  
  .feature-block.reverse {
    direction: rtl;
  }
  
  .feature-block.reverse > * {
    direction: ltr;
  }
  
  .subtext {
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: var(--space-2);
  }
  
  h2 {
    font-size: 2.5rem;
    margin-bottom: var(--space-4);
  }
  
  .description {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: var(--space-6);
    line-height: 1.6;
  }
  
  .feature-visual {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: var(--radius-xl);
  }
  
  .visual-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(20,20,21,0.5), rgba(30,30,32,0.8)), url('/meatflow_dashboard_mockup_1773873730944.png');
    background-size: cover;
    background-position: center;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
  }
  
  .feature-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-subtle);
  }

  @media (max-width: 900px) {
    .feature-block {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      direction: ltr !important;
    }
  }
</style>
