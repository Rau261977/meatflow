---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import FeatureBlock from '../components/FeatureBlock.astro';
---

<Layout title="Run your meat business smarter">
  <!-- Hero Section -->
  <section class="hero container">
    <div class="hero-content">
      <div class="hero-badge glass-panel">
        <span class="badge-dot"></span> Professional Operations Platform
      </div>
      <h1 class="hero-title">
        Run your meat <br/>
        <span class="text-gradient-accent">business smarter</span>
      </h1>
      <p class="hero-subtitle">
        Customer engagement, ordering, and automation platform built for modern meat businesses.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary btn-lg">Request demo</a>
        <a href="/contact" class="btn btn-secondary btn-lg">Talk to sales</a>
      </div>
      <p class="trust-line text-muted mt-base">
        Built for professional meat markets in the United States
      </p>
    </div>
    <div class="hero-visual">
      <!-- Decorative UI mockup representation -->
      <div class="mockup-frame glass-panel">
        <div class="mockup-header">
          <div class="dots"><span></span><span></span><span></span></div>
          <div class="url">meatflow.com/dashboard</div>
        </div>
        <div class="mockup-body">
          <div class="mockup-sidebar"></div>
          <div class="mockup-content">
            <div class="mockup-card line-chart"></div>
            <div class="mockup-card flex-row">
              <div class="mockup-metric"></div>
              <div class="mockup-metric"></div>
              <div class="mockup-metric"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Logos Section -->
  <section class="logos-section container">
    <p class="logos-title text-muted">MeatFlow connects to your existing POS</p>
    <div class="logos-grid">
      <div class="logo-item">Square</div>
      <div class="logo-item">Toast</div>
      <div class="logo-item">Clover</div>
      <div class="logo-item">Lightspeed</div>
      <div class="logo-item text-gradient-accent">Unified API</div>
    </div>
  </section>

  <!-- Core Value Proposition -->
  <section class="features-grid-section container">
    <div class="section-header text-center">
      <h2 class="section-title">Engineered for growth</h2>
      <p class="section-subtitle">MeatFlow integrates enterprise-grade automation and customer intelligence into your existing digital infrastructure.</p>
    </div>
    
    <div class="grid-3">
      <Card 
        icon="📱"
        title="Customer Mobile App"
        description="Launch your own branded iOS and Android applications for high-conversion mobile ordering and loyalty."
      />
      <Card 
        icon="🧠"
        title="AI Assistant"
        description="Deploy an intelligent assistant to automate recommendations and pairing suggestions for your customers."
      />
      <Card 
        icon="📈"
        title="Growth Automation"
        description="Execute data-driven campaigns to reward loyalty and win back customers through automated workflows."
      />
    </div>
  </section>

  <!-- Trust & Why Section -->
  <section class="trust-container container">
    <div class="grid-2">
      <div class="trust-block">
        <h3>Built for Meat Businesses</h3>
        <p>MeatFlow is specifically engineered for the unique taxonomy and operational requirements of high-volume specialty meat retail. From weight-based variations to complex inventory matrices, we understand your business.</p>
      </div>
      <div class="trust-block">
        <h3>Secure and Scalable</h3>
        <p>Leverage an enterprise-grade cloud infrastructure designed to scale from single-location artisan shops to national franchise networks with 99.9% guaranteed uptime.</p>
      </div>
    </div>
  </section>

  <!-- Feature Blocks -->
  <section class="deep-dive-section container">
    <FeatureBlock
      subtext="Operations"
      title="Multi-Store Management"
      image="/meatflow_dashboard_mockup_1773873730944.png"
      description="Manage operations across all your locations from a single platform. Centralized reporting, localized inventory, and franchise-ready tools."
    >
      <div slot="actions">
        <ul class="feature-list">
          <li>✓ Global menu management</li>
          <li>✓ Location-specific diagnostics</li>
          <li>✓ Cross-channel loyalty data</li>
        </ul>
        <a href="/enterprise" class="btn btn-secondary mt-base">See how it works</a>
      </div>
    </FeatureBlock>

    <FeatureBlock
      reverse={true}
      subtext="Data & CRM"
      title="Unified Customer Profiles"
      image="/meatflow_mobile_app_mockup_1773873924788.png"
      description="Sync purchase data from your POS to build complete customer profiles and drive personalized marketing."
    >
      <div slot="actions">
        <ul class="feature-list">
          <li>✓ POS-integrated CRM</li>
          <li>✓ RFM segment automation</li>
          <li>✓ Automated SMS outreach</li>
        </ul>
        <a href="/platform" class="btn btn-secondary mt-base">Talk to sales</a>
      </div>
    </FeatureBlock>
  </section>

  <!-- Final CTA -->
  <section class="cta-section container">
    <div class="cta-card glass-panel text-center">
      <h2>The platform for modern meat markets</h2>
      <p class="cta-desc">Join leading US specialty retailers using MeatFlow to modernize their customer experience.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary btn-lg">Book a call</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Base spacing utility */
  .mt-base {
    margin-top: var(--space-4);
  }
  
  .text-center {
    text-align: center;
  }

  /* Hero Section */
  .hero {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--space-8);
    align-items: center;
    padding: var(--space-8) var(--space-4) var(--space-12);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: var(--space-6);
    color: var(--text-muted);
  }
  
  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--accent-primary);
    box-shadow: 0 0 10px var(--accent-primary);
  }

  .hero-title {
    font-size: 4rem;
    line-height: 1.1;
    margin-bottom: var(--space-4);
    letter-spacing: -0.04em;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: var(--space-6);
    max-width: 520px;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
  }

  .btn-lg {
    padding: var(--space-3) var(--space-6);
    font-size: 1.1rem;
  }

  /* Mockup Visual */
  .mockup-frame {
    width: 100%;
    aspect-ratio: 16/10;
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: var(--shadow-glow);
    transform: perspective(1000px) rotateY(-5deg) rotateX(5deg);
    transition: transform 0.5s ease;
  }
  
  .mockup-frame:hover {
    transform: perspective(1000px) rotateY(0deg) rotateX(0deg);
  }

  .mockup-header {
    height: 30px;
    border-bottom: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    padding: 0 var(--space-3);
    gap: var(--space-3);
    background: rgba(0,0,0,0.2);
  }

  .dots {
    display: flex;
    gap: 6px;
  }

  .dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border-strong);
  }

  .url {
    font-size: 0.7rem;
    color: var(--text-muted);
    background: rgba(255,255,255,0.05);
    padding: 2px 10px;
    border-radius: var(--radius-sm);
    flex-grow: 1;
    text-align: center;
  }

  .mockup-body {
    display: flex;
    flex-grow: 1;
  }

  .mockup-sidebar {
    width: 60px;
    border-right: 1px solid var(--border-subtle);
    background: rgba(0,0,0,0.1);
  }

  .mockup-content {
    flex-grow: 1;
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .mockup-card {
    background: rgba(255,255,255,0.03);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
  }

  .line-chart {
    height: 40%;
  }

  .flex-row {
    height: 30%;
    display: flex;
    gap: var(--space-2);
    border: none;
    background: none;
  }

  .mockup-metric {
    flex: 1;
    background: rgba(255,255,255,0.03);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
  }

  /* Logos Section */
  .logos-section {
    padding: var(--space-6) var(--space-4);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    text-align: center;
  }

  .logos-title {
    font-size: 0.9rem;
    margin-bottom: var(--space-4);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .logos-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .logo-item {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-muted);
    opacity: 0.7;
    transition: opacity var(--transition-normal), color var(--transition-normal);
  }

  .logo-item:hover {
    opacity: 1;
    color: var(--text-main);
  }

  /* Features Grid Section */
  .features-grid-section {
    padding: var(--space-16) var(--space-4);
  }

  .section-header {
    margin-bottom: var(--space-12);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-title {
    font-size: 2.5rem;
    margin-bottom: var(--space-3);
  }

  .section-subtitle {
    font-size: 1.15rem;
    color: var(--text-muted);
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  /* Trust Section */
  .trust-container {
    padding: var(--space-12) var(--space-4);
    border-top: 1px solid var(--border-subtle);
  }

  .trust-block h3 {
    font-size: 1.5rem;
    margin-bottom: var(--space-3);
    color: var(--text-main);
  }

  .trust-block p {
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 1.1rem;
    max-width: 500px;
  }
  
  /* Deep Dive Section */
  .deep-dive-section {
    padding: var(--space-8) var(--space-4);
  }

  .feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    color: var(--text-muted);
  }

  .feature-list li {
    font-size: 1.05rem;
  }

  /* CTA Section */
  .cta-section {
    padding: var(--space-12) var(--space-4) var(--space-16);
  }

  .cta-card {
    padding: var(--space-12) var(--space-6);
    border-radius: var(--radius-xl);
    position: relative;
    overflow: hidden;
  }
  
  .cta-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
  }

  .cta-card h2 {
    font-size: 3rem;
    margin-bottom: var(--space-4);
  }

  .cta-desc {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: var(--space-8);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-12);
    }
    
    .hero-badge {
      margin: 0 auto var(--space-6);
    }
    
    .hero-subtitle {
      margin: 0 auto var(--space-6);
    }
    
    .hero-actions {
      justify-content: center;
    }
    
    .grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 3rem;
    }
    
    .grid-3 {
      grid-template-columns: 1fr;
    }
    
    .cta-card h2 {
      font-size: 2.5rem;
    }
    
    .hero-actions {
      flex-direction: column;
    }
  }
</style>
